# Supabase (Phase 0 — accounts, player data, moments)
# Get these from your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row Level Security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Existing S3 setup (print-order pipeline, reused for Emblem OS media)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Resend (Phase 1 — guardian-invite emails, sent directly via Resend's API,
# separate from Supabase Auth's own emails which go through Supabase's SMTP
# settings). Same Resend account as the one connected there.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Shopify webhook (Post-Matt Checklist item #2 — replaces manual /staff/queue
# Approve for orders/paid events).
# SHOPIFY_WEBHOOK_SECRET = the Signature secret shown when creating the
# 'Order paid' webhook in Shopify Admin -> Settings -> Notifications ->
# Webhooks. Rotate by regenerating in Shopify + updating this value.
# SHOPIFY_STORE_DOMAIN = the *.myshopify.com host (used by src/lib/shopify.ts;
# not required by the webhook handler itself but documented here for parity).
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_STORE_DOMAIN=

# UK card checkout (builder -> Shopify cart permalink). The Shopify variant
# ID of the "Emblem UK Player Card" product. Unset = builder falls back to
# the manual "we'll email a payment link" flow. NEXT_PUBLIC_* because the
# cart URL is built client-side at the end of the builder.
NEXT_PUBLIC_SHOPIFY_UK_CARD_VARIANT=
