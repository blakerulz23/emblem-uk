{
  "root": "YC_CHROME_LEGACY_BACK",
  "template": {
    "template_key": "yc_chrome_legacy_back",
    "version": "1.0.0",
    "canvas": {
      "width": 1054,
      "height": 1492,
      "unit": "px"
    }
  },
  "data_contract": {
    "required": [
      "player_name",
      "athlete_story",
      "collection_name"
    ],
    "optional": [
      "language_code",
      "theme_variant",
      "sport_variant",
      "unlock_items",
      "partner_badge",
      "verification_badge"
    ],
    "fields": {
      "player_name": {
        "layer": "DATA_PLAYER_NAME",
        "source": "athletes.display_name",
        "type": "string",
        "max_chars": 36
      },
      "athlete_story": {
        "layer": "DATA_ATHLETE_STORY",
        "source": "athlete_profiles.story_short",
        "type": "string",
        "max_chars": 420,
        "max_lines": 7
      },
      "dna": {
        "type": "array",
        "length": 5,
        "item": {
          "trait_key": "string",
          "label": "string",
          "score_value": "integer",
          "score_percent": "integer"
        },
        "source": "athlete_trait_scores + dna_traits"
      },
      "nfc": {
        "type": "object",
        "source": "cards + nfc_targets + card_unlock_features",
        "fields": {
          "enabled": "boolean",
          "label": "string",
          "unlock_title": "string",
          "target_url": "string",
          "items": "array"
        }
      },
      "collection_name": {
        "layer": "DATA_COLLECTION_NAME",
        "source": "card_collections.name",
        "type": "string",
        "max_chars": 32
      }
    }
  },
  "database_schema": {
    "athletes": [
      "id",
      "org_id",
      "first_name",
      "last_name",
      "display_name",
      "sport",
      "primary_position",
      "team_id",
      "grad_year",
      "hometown_city",
      "hometown_state",
      "verified",
      "status",
      "created_at",
      "updated_at"
    ],
    "athlete_profiles": [
      "id",
      "athlete_id",
      "story_short",
      "story_long",
      "profile_url",
      "highlights_url",
      "socials_url",
      "latest_updates_url",
      "exclusive_content_url",
      "updated_at"
    ],
    "dna_traits": [
      "id",
      "trait_key",
      "label",
      "icon_key",
      "display_order",
      "active"
    ],
    "athlete_trait_scores": [
      "id",
      "athlete_id",
      "trait_id",
      "score_value",
      "score_percent",
      "updated_at"
    ],
    "card_templates": [
      "id",
      "template_key",
      "version",
      "side",
      "width_px",
      "height_px",
      "metadata",
      "active"
    ],
    "card_collections": [
      "id",
      "name",
      "season",
      "theme_variant",
      "active"
    ],
    "cards": [
      "id",
      "athlete_id",
      "template_id",
      "collection_id",
      "serial_number",
      "language_code",
      "nfc_enabled",
      "nfc_target_id",
      "render_status",
      "created_at"
    ],
    "nfc_targets": [
      "id",
      "athlete_id",
      "target_type",
      "target_url",
      "short_url",
      "active",
      "updated_at"
    ],
    "card_unlock_features": [
      "id",
      "card_id",
      "feature_key",
      "label",
      "icon_key",
      "display_order",
      "enabled"
    ],
    "render_jobs": [
      "id",
      "card_id",
      "side",
      "output_format",
      "dpi",
      "status",
      "retry_count",
      "error_message",
      "output_asset_url",
      "requested_at",
      "completed_at"
    ]
  },
